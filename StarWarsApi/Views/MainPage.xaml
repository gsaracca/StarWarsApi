<Page
    x:Class="StarWarsApi.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:StarWarsApi.Converters"
    xmlns:vm="using:StarWarsApi.ViewModels"
    Background="{StaticResource SpaceBlackBrush}">

    <Page.Resources>
        <conv:HexStringToBrushConverter         x:Key="HexToBrush"         />
        <conv:BoolToVisibilityConverter          x:Key="BoolToVis"          />
        <conv:InverseBoolToVisibilityConverter   x:Key="InvBoolToVis"       />
        <conv:StringToImageSourceConverter       x:Key="StringToImageSource" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"  />    <!-- TitleBar drag region     -->
            <RowDefinition Height="Auto"/>    <!-- Header / Logo            -->
            <RowDefinition Height="Auto"/>    <!-- Search bar               -->
            <RowDefinition Height="Auto"/>    <!-- Quick-search chips       -->
            <RowDefinition Height="*"   />    <!-- Main content area        -->
            <RowDefinition Height="Auto"/>    <!-- Status bar               -->
        </Grid.RowDefinitions>

        <!-- ─── Title Bar drag region ───────────────────────────────────── -->
        <Border Grid.Row="0"
                x:Name="TitleBarDragArea"
                Background="{StaticResource SpaceBlackBrush}" />

        <!-- ─── App Header ───────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Padding="0,24,0,28"
                    Spacing="10">

            <TextBlock Text="★  STAR WARS EXPLORER  ★"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource StarWarsYellowBrush}"
                       HorizontalAlignment="Center"
                       CharacterSpacing="250" />

            <TextBlock Text="Explore the galaxy — characters · films · starships · vehicles · species · planets"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ─── Search Bar ────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="80,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"    />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- AutoSuggestBox with Star Wars styling -->
            <Border Grid.Column="0"
                    CornerRadius="8,0,0,8"
                    BorderThickness="2,2,0,2"
                    BorderBrush="{StaticResource StarWarsYellowBrush}"
                    Background="{StaticResource SpaceSurfaceBrush}">
                <AutoSuggestBox
                    x:Name="SearchBox"
                    PlaceholderText="Search the galaxy…  e.g. Tatooine · Millennium Falcon · Darth Vader"
                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ItemsSource="{x:Bind ViewModel.FilteredSuggestions, Mode=OneWay}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    FontSize="15"
                    BorderThickness="0"
                    Background="Transparent"
                    Padding="14,10"
                    QuerySubmitted="SearchBox_QuerySubmitted"
                    TextChanged="SearchBox_TextChanged"
                    SuggestionChosen="SearchBox_SuggestionChosen" />
            </Border>

            <!-- Search Button -->
            <Button Grid.Column="1"
                    Content="  Search  "
                    Command="{x:Bind ViewModel.SearchCommand}"
                    Background="{StaticResource StarWarsYellowBrush}"
                    Foreground="#000000"
                    FontSize="14"
                    FontWeight="SemiBold"
                    CornerRadius="0,8,8,0"
                    Padding="20,0"
                    MinHeight="48"
                    BorderThickness="0" />
        </Grid>

        <!-- ─── Quick-Search Chips ────────────────────────────────────────── -->
        <StackPanel Grid.Row="3" Margin="80,14,80,0" Spacing="6">

            <TextBlock Text="Quick searches:"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}" />

            <ScrollViewer HorizontalScrollMode="Auto"
                          VerticalScrollMode="Disabled"
                          HorizontalScrollBarVisibility="Hidden">
                <ItemsRepeater x:Name="ExampleChipsRepeater"
                               ItemsSource="{x:Bind ViewModel.ExampleQueries}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="6" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Content="{x:Bind}"
                                    Click="ExampleChip_Click"
                                    Padding="12,4"
                                    CornerRadius="12"
                                    Background="{StaticResource SpaceSurfaceVariantBrush}"
                                    Foreground="{StaticResource StarWarsYellowBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    FontSize="12" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </StackPanel>

        <!-- ─── Main Content Area ─────────────────────────────────────────── -->
        <Grid Grid.Row="4" Margin="0,20,0,0">

            <!-- Loading State -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="18"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="52"
                              Height="52"
                              Foreground="{StaticResource StarWarsYellowBrush}" />
                <TextBlock Text="Scanning the galaxy…"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Welcome State -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14"
                        Visibility="{x:Bind ViewModel.ShowWelcome, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="🚀"
                           FontSize="52"
                           HorizontalAlignment="Center" />
                <TextBlock Text="May the Force be with your search."
                           FontSize="20"
                           FontStyle="Italic"
                           Foreground="{StaticResource StarWarsYellowBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Type any term above — or click a quick-search chip to begin exploring."
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- No Results State -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14"
                        Visibility="{x:Bind ViewModel.HasNoResults, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="🌌"
                           FontSize="52"
                           HorizontalAlignment="Center" />
                <TextBlock Text="These aren't the droids you're looking for."
                           FontSize="18"
                           FontStyle="Italic"
                           Foreground="{StaticResource StarWarsYellowBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="No results found in this sector. Try a broader or different term."
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Results State -->
            <ScrollViewer Padding="80,0,80,24"
                          Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.ResultGroups, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchResultGroup">
                            <StackPanel Spacing="14" Margin="0,0,0,36">

                                <!-- Category header row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"    />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind CategoryHeader}"
                                               FontSize="19"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource StarWarsYellowBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind PageInfo}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,2" />
                                </Grid>

                                <!-- Category separator -->
                                <Rectangle Height="1"
                                           Fill="{StaticResource BorderSubtleBrush}"
                                           Margin="0,-4,0,0" />

                                <!-- Result cards grid -->
                                <ItemsRepeater ItemsSource="{x:Bind Items}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="280"
                                                           ItemsStretch="Fill"
                                                           MinRowSpacing="12"
                                                           MinColumnSpacing="12" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SearchResultItem">
                                            <Border Background="#13131E"
                                                    CornerRadius="10"
                                                    BorderThickness="1">
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="#33FFE81F" />
                                                </Border.BorderBrush>
                                                <StackPanel>

                                                    <!-- ── Image area ──────────────────────────
                                                         Two layers in a Grid:
                                                         1) Fallback: dark bg + oversized category icon
                                                         2) Actual image on top (transparent on 404)
                                                         The outer Border clips both to rounded top corners. -->
                                                    <Border Height="155"
                                                            CornerRadius="10,10,0,0"
                                                            Background="#1A1A2A">
                                                        <Grid>
                                                            <!-- Fallback layer (always present, hidden by image on success) -->
                                                            <TextBlock Text="{x:Bind CategoryIcon}"
                                                                       FontSize="52"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Opacity="0.20" />

                                                            <!-- Image layer (transparent/nothing on 404 — fallback shows through) -->
                                                            <Image Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSource}}"
                                                                   Stretch="UniformToFill"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>

                                                    <!-- ── Text content ──────────────────────── -->
                                                    <StackPanel Spacing="7" Padding="14,11,14,14">

                                                        <!-- Category badge -->
                                                        <Border CornerRadius="4"
                                                                Padding="7,2"
                                                                HorizontalAlignment="Left"
                                                                Background="{x:Bind CategoryAccentHex, Converter={StaticResource HexToBrush}}">
                                                            <TextBlock Text="{x:Bind CategoryBadge}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#000000"
                                                                       CharacterSpacing="50" />
                                                        </Border>

                                                        <!-- Resource name -->
                                                        <TextBlock Text="{x:Bind Name}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#E1E1EF"
                                                                   TextWrapping="Wrap"
                                                                   MaxLines="2" />

                                                        <!-- Subtitle -->
                                                        <TextBlock Text="{x:Bind Subtitle}"
                                                                   FontSize="12"
                                                                   Foreground="#8A8A9A"
                                                                   TextWrapping="Wrap" />

                                                        <!-- Detail lines -->
                                                        <StackPanel Spacing="3" Margin="0,4,0,0">
                                                            <TextBlock Text="{x:Bind Detail1}"
                                                                       FontSize="11"
                                                                       Foreground="#5A5A6A" />
                                                            <TextBlock Text="{x:Bind Detail2}"
                                                                       FontSize="11"
                                                                       Foreground="#5A5A6A" />
                                                            <TextBlock Text="{x:Bind Detail3}"
                                                                       FontSize="11"
                                                                       Foreground="#5A5A6A" />
                                                        </StackPanel>

                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

        </Grid>

        <!-- ─── Status Bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="5"
                Background="{StaticResource SpaceSurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="80,8">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </Border>

    </Grid>
</Page>
