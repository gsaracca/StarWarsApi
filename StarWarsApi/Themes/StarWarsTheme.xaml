<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         STAR WARS EXPLORER — Design Tokens
         Palette: deep-space blacks  ·  Star Wars yellow  ·  subtle category accents
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Colors -->
    <Color x:Key="ColorSpaceBlack">#FF0A0A0F</Color>
    <Color x:Key="ColorSpaceSurface">#FF13131E</Color>
    <Color x:Key="ColorSpaceSurfaceVariant">#FF1C1C2E</Color>
    <Color x:Key="ColorSpaceSurfaceHover">#FF222236</Color>
    <Color x:Key="ColorStarWarsYellow">#FFFFE81F</Color>
    <Color x:Key="ColorStarWarsYellowDim">#CCFFE81F</Color>
    <Color x:Key="ColorBorderSubtle">#33FFE81F</Color>
    <Color x:Key="ColorBorderMedium">#66FFE81F</Color>
    <Color x:Key="ColorTextPrimary">#FFE1E1EF</Color>
    <Color x:Key="ColorTextSecondary">#FF8A8A9A</Color>
    <Color x:Key="ColorTextMuted">#FF5A5A6A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SpaceBlackBrush"          Color="{StaticResource ColorSpaceBlack}" />
    <SolidColorBrush x:Key="SpaceSurfaceBrush"        Color="{StaticResource ColorSpaceSurface}" />
    <SolidColorBrush x:Key="SpaceSurfaceVariantBrush" Color="{StaticResource ColorSpaceSurfaceVariant}" />
    <SolidColorBrush x:Key="SpaceSurfaceHoverBrush"   Color="{StaticResource ColorSpaceSurfaceHover}" />
    <SolidColorBrush x:Key="StarWarsYellowBrush"      Color="{StaticResource ColorStarWarsYellow}" />
    <SolidColorBrush x:Key="StarWarsYellowDimBrush"   Color="{StaticResource ColorStarWarsYellowDim}" />
    <SolidColorBrush x:Key="BorderSubtleBrush"        Color="{StaticResource ColorBorderSubtle}" />
    <SolidColorBrush x:Key="BorderMediumBrush"        Color="{StaticResource ColorBorderMedium}" />
    <SolidColorBrush x:Key="TextPrimaryBrush"         Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush"       Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush"           Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="TransparentBrush"         Color="Transparent" />

</ResourceDictionary>
